# ── Celery ML worker — CPU-only build ────────────────────────────────────────
# Separate from the web Dockerfile so ML deps don't bloat the API image.
# CPU-only torch: ~180 MB runtime vs ~800 MB for the CUDA build.
# ──────────────────────────────────────────────────────────────────────────────

# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .

RUN pip install --no-cache-dir --upgrade pip

# Step 1 — CPU-only PyTorch stack (must happen before anything that depends on
# torch, otherwise pip resolves to the CUDA wheel and pulls 13 nvidia-* packages
# + triton totalling ~3 GB).  torchvision is a direct dep of torchxrayvision.
RUN pip install --no-cache-dir \
        torch torchvision \
        --index-url https://download.pytorch.org/whl/cpu

# Step 2 — ML vision stack (all packages except segment_anything).
# torch/torchvision are already satisfied; pip will not reinstall them.
# timm + huggingface_hub + transformers are needed for RETFound and the skin model.
# opencv-python-headless is needed for retina preprocessing (cv2).
# segment_anything is intentionally excluded here — see Step 3.
RUN pip install --no-cache-dir \
        torchxrayvision \
        scikit-image \
        timm \
        huggingface_hub \
        transformers \
        opencv-python-headless

# Step 3 — LiteMedSAM (installed LAST so it always wins over any standard
# segment-anything that may have been pulled in as a transitive dep).
# Cloning explicitly avoids pip's unreliable VCS backend (git+https://).
RUN git clone --depth=1 --branch LiteMedSAM \
        https://github.com/bowang-lab/MedSAM.git /tmp/LiteMedSAM \
    && pip install --no-cache-dir /tmp/LiteMedSAM \
    && rm -rf /tmp/LiteMedSAM

# Step 4 — rest of the application (FastAPI, Celery, DB drivers, etc.)
# Using prod-no-ml so pip does not re-evaluate the ML group and accidentally
# pull the CUDA wheel.
RUN pip install --no-cache-dir -e ".[prod-no-ml]"


# ── Stage 2: runtime ──────────────────────────────────────────────────────────
FROM python:3.11-slim AS production

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libpq5 \
    # scikit-image / PIL runtime deps
    libjpeg62-turbo \
    zlib1g \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

COPY app/ ./app/
COPY alembic/ ./alembic/
COPY alembic.ini .

RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser

# HuggingFace Hub writes cache and xet logs to $HF_HOME (~/.cache/huggingface by default).
# System users created with --system have /nonexistent as their home dir, which causes
# Permission denied errors on first model download. Point HF_HOME to writable /tmp instead.
ENV HF_HOME=/tmp/huggingface

USER appuser

# Single-concurrency worker — one diagnosis at a time to keep memory flat.
# TorchXRayVision model is loaded once via @lru_cache and reused across tasks.
CMD ["celery", "-A", "app.core.celery_app", "worker", \
     "--loglevel=info", "--concurrency=1", \
     "--queues=celery"]
