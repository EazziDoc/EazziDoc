# Database
DATABASE_URL=postgresql+asyncpg://user:password@host/eazzidoc

# Redis
REDIS_URL=redis://default:password@host:port

# Auth
SECRET_KEY=generate-a-256-bit-secret-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage — Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=eazzidoc-images
CLOUDFLARE_R2_PUBLIC_URL=

# AI — Report Generation
GOOGLE_API_KEY=
GROQ_API_KEY=

# AI — Vision Models
HUGGINGFACE_API_KEY=

# Email / SMTP (SSL, port 465)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
REPORT_EMAIL_BCC=
FRONTEND_URL=http://localhost:3000

# Monitoring
SENTRY_DSN=

# App
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
